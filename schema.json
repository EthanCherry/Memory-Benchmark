{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LarkMemory Benchmark Dataset Schema v4",
  "description": "Schema for MemScope-style dataset files (metadata header + test_cases array). For legacy JSONL files, use schema.v3.json.",
  "version": "4.0.0",
  "type": "object",
  "required": ["dataset_name", "version", "total_cases", "test_cases"],
  "properties": {
    "dataset_name": {
      "type": "string",
      "description": "Name of the dataset, e.g. command_memory, decision_memory",
      "enum": ["command_memory", "decision_memory", "preference_memory", "knowledge_health"]
    },
    "version": {
      "type": "string",
      "description": "Dataset format version"
    },
    "description": {
      "type": "string",
      "description": "Dataset description"
    },
    "total_cases": {
      "type": "integer",
      "description": "Total number of test cases in this file",
      "minimum": 0
    },
    "difficulty_distribution": {
      "type": "object",
      "description": "Count of cases by difficulty level",
      "additionalProperties": { "type": "integer" }
    },
    "test_cases": {
      "type": "array",
      "description": "Array of test cases",
      "minItems": 1,
      "items": {
        "type": "object",
        "description": "Test case in MemScope-style format with conversational setup",
        "required": ["test_id", "name", "setup", "query", "expected", "difficulty"],
        "properties": {
          "test_id": {
            "type": "string",
            "description": "Unique identifier, format: {direction_abbr}_{test_type_abbr}_{NNN}",
            "pattern": "^[a-z]+_[a-z]+_[0-9]{3}$",
            "examples": ["cmd_eff_001", "dec_anti_002", "pref_abs_003", "kh_xproj_004"]
          },
          "name": {
            "type": "string",
            "description": "Short human-readable name for this test case"
          },
          "description": {
            "type": "string",
            "description": "Detailed description including scenario, noise count, and test type"
          },
          "setup": {
            "type": "object",
            "description": "Setup data including conversational messages",
            "required": ["messages"],
            "properties": {
              "messages": {
                "type": "array",
                "description": "Conversational messages representing the events to be ingested",
                "minItems": 1,
                "items": {
                  "description": "A single message in a conversational setup, similar to MemScope format",
                  "type": "object",
                  "required": ["role", "content"],
                  "properties": {
                    "role": {
                      "type": "string",
                      "description": "Role of the message sender: user, assistant, or a custom name (e.g. 技术负责人)",
                      "examples": ["user", "assistant", "技术负责人", "产品经理"]
                    },
                    "content": {
                      "type": "string",
                      "description": "Message content"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "description": "ISO 8601 datetime"
                    },
                    "context": {
                      "type": "object",
                      "description": "Additional context (project, user_id, etc.)",
                      "properties": {
                        "project": { "type": "string" },
                        "cwd": { "type": "string" },
                        "user_id": { "type": "string" },
                        "chat_id": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "context": {
                "type": "object",
                "description": "Additional context for this test case"
              }
            }
          },
          "query": {
            "description": "The retrieval query or task trigger sent to the memory system after ingestion",
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["type", "content"],
                "properties": {
                  "type": { "type": "string" },
                  "content": { "type": "string" },
                  "keyword": { "type": "string" }
                }
              }
            ]
          },
          "expected": {
            "type": "object",
            "description": "Ground truth for scoring this case. Uses two-layer scoring: answer_correct + evidence_correct.",
            "required": ["should_retrieve"],
            "properties": {
              "should_retrieve": {
                "type": "boolean",
                "description": "Whether the system should return a non-empty, relevant result"
              },
              "memory_type": {
                "type": "string",
                "enum": ["decision", "preference", "command", "knowledge", "event"]
              },
              "answer_keywords": {
                "type": "array",
                "items": { "type": "string" }
              },
              "should_not_contain": {
                "type": "array",
                "items": { "type": "string" }
              },
              "current_value": { "type": "string" },
              "inactive_values": {
                "type": "array",
                "items": { "type": "string" }
              },
              "forbidden_active_values": {
                "type": "array",
                "items": { "type": "string" }
              },
              "allow_historical_mention": {
                "type": "boolean",
                "default": false
              },
              "evidence_event_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "superseded_event_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "suggested_command": { "type": "string" },
              "baseline_chars": { "type": "integer", "minimum": 0 },
              "actual_chars": { "type": "integer", "minimum": 0 },
              "min_saving_rate": { "type": "number", "minimum": 0, "maximum": 1 },
              "baseline_steps": { "type": "integer", "minimum": 0 },
              "actual_steps": { "type": "integer", "minimum": 0 },
              "min_step_saving_rate": { "type": "number", "minimum": 0, "maximum": 1 },
              "decision": { "type": "string" },
              "reason": { "type": "string" },
              "rejected_option": { "type": "string" },
              "preference_key": { "type": "string" },
              "preference_value": { "type": "string" },
              "condition": { "type": "string" },
              "abstention_keywords": {
                "type": "array",
                "items": { "type": "string" }
              },
              "hallucination_triggers": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"]
          },
          "priority": {
            "type": "string",
            "description": "Priority level, e.g. P0, P1, P2",
            "pattern": "^P[0-9]+$"
          },
          "tags": {
            "type": "array",
            "description": "Tags for categorizing and filtering test cases",
            "items": { "type": "string" }
          },
          "metrics": {
            "type": "array",
            "description": "List of metric IDs to evaluate for this case",
            "items": {
              "type": "string",
              "enum": [
                "recall_at_1",
                "recall_at_3",
                "keyword_match",
                "evidence_match",
                "evidence_source_accuracy",
                "should_not_contain_match",
                "latest_value_accuracy",
                "old_value_suppression",
                "inactive_value_mention",
                "noise_robustness",
                "top1_hit",
                "command_exact_match",
                "char_saving_rate",
                "step_saving_rate",
                "decision_match",
                "reason_match",
                "rejected_option_match",
                "preference_match",
                "condition_match",
                "conflict_resolution_accuracy",
                "freshness_accuracy",
                "expired_memory_suppression",
                "long_term_recall",
                "abstention_accuracy",
                "hallucination_rate",
                "cross_project_leakage_rate",
                "scope_accuracy"
              ]
            }
          },
          "time_span_days": {
            "type": "integer",
            "minimum": 0
          },
          "input_events": {
            "deprecated": true,
            "description": "Kept for backward compatibility. Use setup.messages instead."
          }
        }
      }
    }
  }
}
